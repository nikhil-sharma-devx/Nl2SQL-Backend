# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<generate-a-32-char-random-string>
JWT_SECRET_KEY=<generate-a-different-32-char-random-string>
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── Google OAuth (optional) ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ── SMTP ──────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=<your-email@gmail.com>
SMTP_PASSWORD=<your-gmail-app-password>
SMTP_FROM_EMAIL=<your-email@gmail.com>

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.0
GROQ_API_KEY=<your-groq-api-key>
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Together AI (fine-tuning only) ────────────────────────────────────────────
TOGETHER_API_KEY=
FINE_TUNING_PROVIDER=together

# ── Embeddings (Gemini API — no local model, no PyTorch) ─────────────────────
EMBEDDING_PROVIDER=gemini
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
EMBEDDING_DIMENSIONS=768

# ── Vector Store — Qdrant Cloud ───────────────────────────────────────────────
VECTOR_STORE_PROVIDER=qdrant
QDRANT_URL=<your-qdrant-cloud-url>
QDRANT_API_KEY=<your-qdrant-cloud-api-key>
QDRANT_COLLECTION_NAME=schema_chunks
VECTOR_STORE_TOP_K=5

# ── Databases — Supabase ──────────────────────────────────────────────────────
DATABASE_URL=<your-supabase-connection-string>
HISTORY_DATABASE_URL=<your-supabase-connection-string>
AVAILABLE_DATABASES=

# ── SQL ───────────────────────────────────────────────────────────────────────
SQL_DIALECT=postgresql
SQL_VALIDATION_ENABLED=true
SQL_MAX_RETRIES=3

# ── Cache — Redis (Docker service name, not localhost) ────────────────────────
CACHE_PROVIDER=redis
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=3600

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60

# ── Schema ────────────────────────────────────────────────────────────────────
AUTO_INGEST_SCHEMA_ON_STARTUP=true
SCHEMA_MONITOR_ENABLED=true
SCHEMA_MONITOR_INTERVAL_SECONDS=300

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=nl-to-sql-rag
OTEL_EXPORTER_OTLP_ENDPOINT=
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
PHOENIX_ACTIVE=false

# ── Langfuse (LLM tracing) ────────────────────────────────────────────────────
LANGFUSE_ENABLED=false
LANGFUSE_SECRET_KEY=<sk-lf-...>
LANGFUSE_PUBLIC_KEY=<pk-lf-...>
LANGFUSE_BASE_URL=https://cloud.langfuse.com
