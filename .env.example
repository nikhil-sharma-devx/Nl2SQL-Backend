# ═══════════════════════════════════════════════════════════════════════════════
#  NL-to-SQL Backend — Environment Variables
#  Copy this file to .env and fill in every value marked REQUIRED.
#  Never commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=production                        # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
# Set to empty string to disable file logging:
APP_LOG_FILE=/app/data/logs/application.log

# ── Security  (REQUIRED — change these!) ─────────────────────────────────────
SECRET_KEY=change-me-use-openssl-rand-hex-32
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080                  # 7 days

# ── Database — Supabase PostgreSQL  (REQUIRED) ───────────────────────────────
# Use the "Direct connection" string from Supabase → Project Settings → Database.
# asyncpg driver is required.
DATABASE_URL=postgresql+asyncpg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
HISTORY_DATABASE_URL=postgresql+asyncpg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Multiple target databases exposed in the UI (JSON map of name → URL):
# AVAILABLE_DATABASES={"Production DB": "postgresql+asyncpg://...","Staging DB": "postgresql+asyncpg://..."}
AVAILABLE_DATABASES=

# ── LLM Provider  (REQUIRED — at least one key) ───────────────────────────────
LLM_PROVIDER=groq                         # groq | openai | anthropic | gemini
LLM_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.0

GROQ_API_KEY=                             # Required when LLM_PROVIDER=groq
OPENAI_API_KEY=                           # Required when LLM_PROVIDER=openai
ANTHROPIC_API_KEY=                        # Required when LLM_PROVIDER=anthropic
GEMINI_API_KEY=                           # Required when LLM_PROVIDER=gemini

# ── Fine-tuning (optional) ────────────────────────────────────────────────────
FINE_TUNING_ENABLED=false
FINE_TUNING_PROVIDER=together             # openai | groq | together
TOGETHER_API_KEY=

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=gemini                 # gemini (API, no local model) | huggingface (local, needs sentence-transformers)
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
EMBEDDING_DIMENSIONS=768
GEMINI_EMBEDDING_API_KEY=                 # leave empty to share GEMINI_API_KEY

# ── Vector Store ──────────────────────────────────────────────────────────────
VECTOR_STORE_PROVIDER=qdrant              # qdrant | chroma | faiss
QDRANT_URL=http://qdrant:6333             # use http://localhost:6333 outside Docker
QDRANT_API_KEY=                           # leave empty for local/self-hosted Qdrant
QDRANT_COLLECTION_NAME=schema_chunks

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_PROVIDER=redis                      # redis | in_memory (auto-redis in production)
REDIS_URL=redis://redis:6379/0            # use redis://localhost:6379/0 outside Docker
CACHE_TTL_SECONDS=3600

SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.95

# ── SQL ───────────────────────────────────────────────────────────────────────
SQL_DIALECT=postgresql                    # postgresql | mysql
SQL_VALIDATION_ENABLED=true
SQL_MAX_RETRIES=3

# ── Query Intelligence ────────────────────────────────────────────────────────
QUERY_REWRITING_ENABLED=true
QUERY_EXPANSION_ENABLED=true
RERANKER_ENABLED=true                     # uses FlashRank (ONNX, no PyTorch — memory-safe)
BM25_ENABLED=true
HYBRID_SEARCH_ALPHA=0.5

# ── Schema Ingestion ──────────────────────────────────────────────────────────
AUTO_INGEST_SCHEMA_ON_STARTUP=true
SCHEMA_MONITOR_ENABLED=true
SCHEMA_MONITOR_INTERVAL_SECONDS=300

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60                    # requests per minute per IP

# ── Authentication ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=                         # same value as VITE_GOOGLE_CLIENT_ID in frontend

# ── Email / SMTP (for OTP verification) ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=                            # your Gmail address
SMTP_PASSWORD=                            # Gmail App Password (not your login password)
SMTP_FROM_EMAIL=noreply@yourdomain.com

# ── Observability (all optional) ──────────────────────────────────────────────
# OpenTelemetry:
OTEL_SERVICE_NAME=nl-to-sql-rag
OTEL_EXPORTER_OTLP_ENDPOINT=             # e.g. http://localhost:4317

# Langfuse:
LANGFUSE_ENABLED=false
LANGFUSE_SECRET_KEY=                         # sk-lf-...
LANGFUSE_PUBLIC_KEY=                         # pk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Arize Phoenix:
PHOENIX_ACTIVE=false
PHOENIX_ENDPOINT=http://localhost:6006/v1/traces
